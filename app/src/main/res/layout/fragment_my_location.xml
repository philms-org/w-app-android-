<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".Main.MyLocationFragment">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:id="@+id/id_top_layout"
            android:layout_width="match_parent"
            android:layout_height="60dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="My Location"
                android:textSize="20sp"
                android:fontFamily="@font/montserrat_semibold"
                android:textColor="@color/white"
                />

            <ImageView
                android:id="@+id/id_info"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="10dp"
                android:padding="2dp"
                android:src="@drawable/icon_info"
                app:tint="@color/blue"
                android:visibility="gone"
                />

        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/id_top_layout">

            <RelativeLayout
                android:id="@+id/id_location_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/id_location_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="16dp"
                    android:text="Current Potential Wings at"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:fontFamily="@font/montserrat_regular"
                    android:maxLines="1"
                    />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/id_location_title"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    android:layout_centerHorizontal="true">

                    <TextView
                        android:id="@+id/id_location_title_text_view"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Label Label Label"
                        android:textSize="18sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/montserrat_semibold"
                        android:maxLines="1"
                        />

                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="8dp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/icon_expand"
                            app:tint="@color/white"
                            />

                    </RelativeLayout>

                </LinearLayout>

            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/id_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@id/id_location_layout"
                />

            <RelativeLayout
                android:id="@+id/id_no_users_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@id/id_location_layout"
                android:layout_marginTop="16dp"
                android:background="@color/black"
                android:visibility="gone">

                <TextView
                    android:id="@+id/id_no_users_title"
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_centerHorizontal="true"
                    android:gravity="center_horizontal"
                    android:text="Browse other Wing Me locations while you wait for someone to
walk through the door"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:fontFamily="@font/montserrat_semibold"
                    />

                <ImageView
                    android:layout_width="360dp"
                    android:layout_height="match_parent"
                    android:layout_below="@id/id_no_users_title"
                    android:layout_above="@id/id_share_app"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="40dp"
                    android:layout_marginBottom="40dp"
                    android:src="@drawable/image_world"
                    />

                <RelativeLayout
                    android:id="@+id/id_share_app"
                    android:layout_width="260dp"
                    android:layout_height="86dp"
                    android:layout_centerHorizontal="true"
                    android:layout_alignParentBottom="true"
                    android:layout_marginBottom="60dp"
                    android:background="@drawable/view_drawable_share_button">

                    <ImageView
                        android:id="@+id/id_share_app_icon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="8dp"
                        android:src="@drawable/icon_share"
                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/id_share_app_icon"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="4dp"
                        android:text="Share Wing Me"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_semibold"
                        android:textColor="@color/white"
                        />

                </RelativeLayout>

            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/id_no_location_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/black">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/image_no_location"
                    android:scaleType="centerCrop"
                    />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/view_drawable_gradient_top_white"
                    android:alpha="0.8"
                    />

                <RelativeLayout
                    android:id="@+id/id_share"
                    android:layout_width="260dp"
                    android:layout_height="86dp"
                    android:layout_centerHorizontal="true"
                    android:layout_alignParentBottom="true"
                    android:layout_marginBottom="60dp"
                    android:background="@drawable/view_drawable_share_button">

                    <ImageView
                        android:id="@+id/id_share_icon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="8dp"
                        android:src="@drawable/icon_share"
                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/id_share_icon"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="4dp"
                        android:text="Share Wing Me"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_semibold"
                        android:textColor="@color/white"
                        />

                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_alignParentBottom="true"
                    android:background="@drawable/view_drawable_gradient_bottom_white"
                    android:alpha="0.8"
                    />

            </RelativeLayout>

            <ProgressBar
                android:id="@+id/id_progress_bar"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_centerInParent="true"
                android:visibility="gone"
                />

        </RelativeLayout>

    </RelativeLayout>

</FrameLayout>