<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".Launch.LoginActivity">

    <RelativeLayout
        android:id="@+id/id_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="10dp"
        />

    <RelativeLayout
        android:id="@+id/id_top_layout"
        android:layout_width="match_parent"
        android:layout_height="70dp">

        <ImageView
            android:id="@+id/id_back"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp"
            android:src="@drawable/icon_back"
            android:padding="7dp"
            app:tint="@color/blue"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/montserrat_semibold"
            android:text="Forgot Password"
            android:textColor="@color/white"
            android:textSize="20sp" />

    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/id_top_layout">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="30dp"
                    android:layout_marginEnd="30dp"
                    android:layout_marginBottom="60dp"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/id_phone_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_semibold"
                            android:text="Phone number"
                            android:textColor="@color/white"
                            android:textSize="16sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_below="@id/id_phone_title"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <RelativeLayout
                                android:layout_width="80dp"
                                android:layout_height="match_parent"
                                android:background="@drawable/view_drawable_edit_text">

                                <TextView
                                    android:id="@+id/id_country_code"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="+1"
                                    android:fontFamily="@font/montserrat_semibold"
                                    android:textSize="16sp"
                                    android:textColor="@color/blue"
                                    android:gravity="center"
                                    />

                            </RelativeLayout>

                            <EditText
                                android:id="@+id/id_phone_edit_text"
                                android:layout_width="match_parent"
                                android:layout_height="50dp"
                                android:layout_marginStart="12dp"
                                android:background="@drawable/view_drawable_edit_text"
                                android:paddingStart="20dp"
                                android:paddingEnd="20dp"
                                android:textSize="14sp"
                                android:textColor="@color/black"
                                android:inputType="phone"
                                />

                        </LinearLayout>

                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/id_code_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp">

                        <TextView
                            android:id="@+id/id_code_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_semibold"
                            android:text="Verification code"
                            android:textColor="@color/white"
                            android:textSize="16sp" />

                        <EditText
                            android:id="@+id/id_code_edit_text"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_below="@id/id_code_title"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/view_drawable_edit_text"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:textSize="14sp"
                            android:textColor="@color/black"
                            android:inputType="number"
                            />

                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/id_password_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp">

                        <TextView
                            android:id="@+id/id_password_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_semibold"
                            android:text="Password"
                            android:textColor="@color/white"
                            android:textSize="16sp" />

                        <EditText
                            android:id="@+id/id_password_edit_text"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_below="@id/id_password_title"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/view_drawable_edit_text"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:textSize="14sp"
                            android:textColor="@color/black"
                            android:inputType="textPassword"
                            />

                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/id_confirm_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp">

                        <TextView
                            android:id="@+id/id_confirm_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_semibold"
                            android:text="Confirm password"
                            android:textColor="@color/white"
                            android:textSize="16sp" />

                        <EditText
                            android:id="@+id/id_confirm_edit_text"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_below="@id/id_confirm_title"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/view_drawable_edit_text"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:textSize="14sp"
                            android:textColor="@color/black"
                            android:inputType="textPassword"
                            />

                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="40dp"
                        android:background="@drawable/view_drawable_button">

                        <TextView
                            android:id="@+id/id_next"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fontFamily="@font/montserrat_semibold"
                            android:gravity="center"
                            android:text="Next"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            />

                        <ProgressBar
                            android:id="@+id/id_next_progress_bar"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_centerInParent="true"
                            android:theme="@style/Light"
                            android:visibility="gone"
                            />

                    </RelativeLayout>

                </LinearLayout>

            </RelativeLayout>

        </ScrollView>

    </RelativeLayout>

</RelativeLayout>