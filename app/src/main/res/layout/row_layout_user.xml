<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:id="@+id/id_relative_layout"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    android:background="@color/black">

    <RelativeLayout
        android:id="@+id/id_image_layout"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_centerVertical="true"
        android:layout_marginStart="16dp"
        android:background="@drawable/view_drawable_user_image_blue">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            app:cardCornerRadius="35dp">

            <ImageView
                android:id="@+id/id_image_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/black"
                android:scaleType="centerCrop"
                />

        </androidx.cardview.widget.CardView>

    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/id_image_layout"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_centerVertical="true"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/id_title_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Label Label Label"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:fontFamily="@font/montserrat_semibold"
                android:maxLines="1"
                />

            <ImageView
                android:id="@+id/id_checkmark"
                android:layout_width="16dp"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/id_title_text_view"
                android:layout_alignTop="@id/id_title_text_view"
                android:layout_alignBottom="@id/id_title_text_view"
                android:layout_marginStart="8dp"
                android:src="@drawable/icon_checkmark"
                app:tint="@color/blue"
                />

        </RelativeLayout>

        <TextView
            android:id="@+id/id_details_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Label Label Label Label Label Label"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:fontFamily="@font/montserrat_regular"
            android:maxLines="1"
            />

    </LinearLayout>

</RelativeLayout>
