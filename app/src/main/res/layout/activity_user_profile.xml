                                            android:layout_alignParentEnd="true"
                                            android:layout_centerVertical="true"
                                            android:layout_marginEnd="20dp"
                                            android:fontFamily="@font/montserrat_semibold"
                                            android:text="Label"
                                            android:textColor="@color/black"
                                            android:textSize="14sp" />

