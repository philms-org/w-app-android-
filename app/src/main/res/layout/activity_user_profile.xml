                                    android:layout_marginEnd="20dp"
                                    android:background="@color/gray" />

                            </RelativeLayout>

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="50dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
